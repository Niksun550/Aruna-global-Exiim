# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls on the client side.
# In Vercel, add this to your Project Settings > Environment Variables.
NEXT_PUBLIC_GEMINI_API_KEY=

# APP_URL: The full URL of your deployed application (e.g., https://aruna-global-exiim.vercel.app).
# Used for metadataBase, self-referential links, and SEO.
APP_URL=
